---
import MainLayout from '../layouts/MainLayout.astro';

const HERO_IMAGE = 'https://static.wixstatic.com/media/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg/v1/fill/w_1200,h_600,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg';
const PARTNERSHIP_URL = 'https://geelong-all-abilities-sports-club.square.site/shop/partnerships/UBOT4MYM7LXY4LJSIWXAELK2?page=1&limit=30&sort_by=category_order&sort_order=asc';
---

<MainLayout
  title="Partner With Us | Sponsor Geelong Stars"
  description="Partner with Geelong Stars and support inclusive sports in our community. Explore sponsorship opportunities and benefits."
  url="/partner-with-us"
>
  <!-- Hero Section -->
  <section class="relative min-h-[400px] flex items-center">
    <div class="absolute inset-0">
      <img
        src={HERO_IMAGE}
        alt="Partner with Geelong Stars"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/80 to-navy/50"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
          Partner With Us
        </h1>
        <p class="text-xl text-white/90">
          Join forces with the Geelong Stars and help make a real difference
          in the lives of people with all abilities.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-10">
        <div class="w-16 h-16 bg-navy/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <!-- Users icon -->
          <svg class="w-8 h-8 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">
          Become a Partner
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-6">
          The Geelong Stars rely on the generous support of local businesses
          and organisations to keep our programs running and accessible for
          everyone. By partnering with us, you're investing in an inclusive
          community where sport brings people together regardless of ability.
        </p>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Whether you're a small business or a large organisation, there are
          partnership opportunities to suit every level. Your support helps
          fund our programs, equipment, venues, and community events — and
          in return, your brand will be proudly associated with one of
          Geelong's most impactful grassroots sporting clubs.
        </p>
      </div>

      <a
        href={PARTNERSHIP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 bg-navy text-white hover:bg-navy-600 focus:ring-navy-300 px-6 py-3 text-base"
      >
        View Partnerships
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-warm-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-navy to-navy-600 rounded-3xl p-8 md:p-12 text-center relative overflow-hidden">
        <div class="absolute top-4 left-8 opacity-20">
          <!-- Heart icon -->
          <svg class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Together We're Stronger
        </h2>
        <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
          Your partnership doesn't just support a club — it supports an
          entire community of athletes, families, and volunteers who believe
          everyone deserves a chance to play.
        </p>
        <a
          href={PARTNERSHIP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 bg-yellow-400 text-navy hover:bg-yellow-300 font-bold focus:ring-navy-300 px-6 py-3 text-base"
        >
          Partner With Us Today
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</MainLayout>
