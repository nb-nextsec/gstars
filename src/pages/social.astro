---
import MainLayout from '../layouts/MainLayout.astro';

const HERO_IMAGE = 'https://static.wixstatic.com/media/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg/v1/fill/w_1200,h_600,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg';

const newsItems = [
  { href: 'https://www.facebook.com/photo?fbid=122191073402448490&set=a.122099181434448490', image: '/images/Jamie-Lee News Article.jpg', badge: 'Exciting News!', badgeColor: 'text-green-600', title: 'On Your Bike... A First For Jamie-Lee', description: 'Twelve year old Jamie-Lee enjoyed her first ever bike ride along the Geelong waterfront on the Dream Rider, just one of Geelong Stars modified bikes enabling inclusive cycling. Read more about Jamie-Lee\'s inspiring first ride on our Facebook page by clicking here.', external: true },
  { href: 'https://timesnewsgroup.com.au/geelongtimes/news/stars-launch-an-innovative-bmx-program/', image: 'https://static.timesnewsgroup.com.au/prod/uploads/sites/21/2025/10/Untitled-design-30-2.jpg', badge: 'In The News!', badgeColor: 'text-cyan-600', title: 'Stars Launch an Innovative BMX Program', description: 'Geelong Stars is launching an all-abilities BMX program with adaptive bikes and inclusive riding opportunities. More than 20 participants have already engaged with our Learn to Ride programs. Read more in the Geelong Times!', external: true },
  { href: 'https://timesnewsgroup.com.au/geelongtimes/news/supporting-active-initiatives/', image: 'https://static.timesnewsgroup.com.au/prod/uploads/sites/21/2025/09/Cr-Melissa-Cadwell.jpg', badge: 'In The News!', badgeColor: 'text-cyan-600', title: 'Supporting Active Initiatives', description: "Geelong's community sports initiatives including all-abilities sporting activities and inclusive programs encouraging broader participation in local sports and recreation. Read more in the Geelong Times!", external: true },
  { image: '/images/Cadel Family Ride 2.jpg', badge: 'Community', badgeColor: 'text-cyan-600', title: 'Geelong Stars Represented at the Cadel Evans Family Ride', description: "Geelong Stars proudly participated in the Cadel Evans Great Ocean Road Race Family Ride, showcasing our commitment to inclusive cycling and community engagement in one of Geelong's biggest sporting events!" },
  { href: 'https://timesnewsgroup.com.au/geelongtimes/news/new-all-abilities-sports-club-to-launch-in-geelong/', image: 'https://static.timesnewsgroup.com.au/prod/uploads/sites/21/2024/10/Your-paragraph-text-2024-10-03T102342.640.png', badge: 'In The News!', badgeColor: 'text-cyan-600', title: 'New All-Abilities Sports Club to Launch in Geelong', description: 'Geelong Stars is launching an inclusive sports program for children with diverse abilities, providing accessible athletic activities and community engagement. Read more in the Geelong Times!', external: true },
  { image: '/images/Football 1.jpg', badge: 'Exciting News!', badgeColor: 'text-green-600', title: 'New Season Registration Open!', description: 'Registration for the new season is now open! Head to our programs page to learn more about our offerings and join the fun. All ages and abilities welcome.' },
  { image: '/images/Basketball 1.jpg', badge: 'Welcome!', badgeColor: 'text-blue-600', title: 'New Members Welcome', description: "We're always welcoming new members to our Geelong Stars family! Come along to a session and see what we're all about. No experience needed - just bring yourself and a smile." },
  { image: '/images/Volunteers 1.jpg', badge: 'Thank You!', badgeColor: 'text-pink-600', title: 'Our Amazing Volunteers', description: 'A big shoutout to all our incredible volunteers who make Geelong Stars possible. Your time and dedication helps our athletes thrive every single week. You\'re all superstars!' },
  { image: '/images/Learn to Ride 3.jpg', badge: 'New Program!', badgeColor: 'text-teal-600', title: 'Learn to Ride Program Launch', description: 'Our brand new Learn to Ride program is up and running! Participants of all ages and abilities are building confidence on two wheels with our supportive coaches. Bikes and helmets provided.' },
  { image: '/images/Achilles Walking Group 1.jpg', badge: 'Community', badgeColor: 'text-orange-600', title: 'Running & Walking Group Growing', description: "Our Sunday morning Running & Walking Group continues to grow! Whether you prefer a brisk walk or a jog, everyone is welcome. It's a great way to stay active and meet new friends." },
  { image: '/images/Golf 7.jpg', badge: 'Highlights', badgeColor: 'text-emerald-600', title: 'Golf Stars Shine on the Course', description: "Our golfers have been putting in the work and it shows! Check out what our Mini's Golf crew have been up to on the course. Skills are improving every week." },
  { image: '/images/boxing 1.jpg', badge: 'Program Update', badgeColor: 'text-red-600', title: 'Stars Boxing in Action', description: 'Our Stars Boxing program is a hit! Participants are building strength, confidence, and fitness while having a blast. Come along and see what all the excitement is about.' },
  { image: '/images/Thursday Meals.jpg', badge: 'Social', badgeColor: 'text-purple-600', title: 'Thursday Night Meals a Hit', description: 'Our Thursday Night Meals are bringing the community together every week! Great food, great company, and great vibes. Everyone is welcome to join us for dinner at the clubrooms.' },
  { image: '/images/basketball minis 1.jpg', badge: 'Sponsors', badgeColor: 'text-amber-600', title: 'Thank You to Our Sponsors', description: 'A huge thank you to all our amazing sponsors who make our programs possible. Your generous support helps us provide inclusive sport for everyone in the Geelong community.' },
];
---

<MainLayout
  title="Social Events & Community | Geelong Stars"
  description="Join our social events and community activities. Connect with other members and families at Geelong Stars."
  url="/social"
>
  <!-- Hero -->
  <section class="relative min-h-[400px] flex items-center">
    <div class="absolute inset-0">
      <img src={HERO_IMAGE} alt="Geelong Stars News and Events" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/80 to-navy/50"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">News and Events</h1>
        <p class="text-xl text-white/90">
          Stay connected with the Geelong Stars community! Check out our upcoming
          events, browse photos, and see what fun we've been having together.
        </p>
      </div>
    </div>
  </section>

  <!-- Stars News -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">Stars News</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">The latest updates and news from Geelong Stars!</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {newsItems.map((item) => {
          const card = (
            <>
              <div class="h-48 overflow-hidden">
                <img src={item.image} alt={item.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              </div>
              <div class="p-6">
                <div class={`text-sm font-semibold mb-2 ${item.badgeColor}`}>{item.badge}</div>
                <h3 class="text-lg font-bold text-navy mb-2">{item.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
              </div>
            </>
          );
          return item.href ? (
            <a href={item.href} target="_blank" rel="noopener noreferrer" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group">{card}</a>
          ) : (
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group">{card}</div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- What's Happening -->
  <section class="py-16 lg:py-24 bg-warm-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-2">What's Happening</h2>
        <p class="text-gray-600">March 2026 — Stars Programs and Special Events</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <img src="/images/March events.jpg" alt="March 2026 Events Calendar - Geelong Stars Programs and Activities" class="w-full h-auto" />
      </div>
    </div>
  </section>

  <!-- Follow Us -->
  <section class="py-16 lg:py-24 bg-gradient-to-r from-navy to-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Follow Us!</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Stay connected with us on social media for the latest updates, photos, and all the fun from our community!
      </p>
      <div class="flex justify-center gap-6 mb-8">
        <a href="https://www.facebook.com/p/Geelong-All-Abilities-Sports-Club-61563454708703/" target="_blank" rel="noopener noreferrer" class="w-14 h-14 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 hover:scale-110 transition-all text-white">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://instagram.com/geelongstars" target="_blank" rel="noopener noreferrer" class="w-14 h-14 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 hover:scale-110 transition-all text-white">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
      <p class="text-white/70 text-sm">Tag us in your photos! #GeelongStars #AllAbilitiesSports</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-yellow-400 to-yellow-500 rounded-3xl p-8 md:p-12 text-center relative overflow-hidden">
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">Want to Join the Fun?</h2>
        <p class="text-xl text-navy/80 mb-8 max-w-2xl mx-auto">
          There's always something happening at Geelong Stars! Get in touch to find out more about joining our community.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 font-medium rounded-lg px-6 py-3 text-base bg-navy text-white hover:bg-navy-600 transition-colors">
            Get In Touch
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="/programs" class="inline-flex items-center justify-center gap-2 font-medium rounded-lg px-6 py-3 text-base border-2 border-navy text-navy hover:bg-navy hover:text-white transition-colors">View Programs</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
