---
import MainLayout from '../layouts/MainLayout.astro';

const HERO_IMAGE = 'https://static.wixstatic.com/media/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg/v1/fill/w_1200,h_600,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg';
const TEAM_IMAGE = 'https://static.wixstatic.com/media/c23ea9_6f77b1dc166242098bc394d398c3deb2~mv2.jpg/v1/fill/w_800,h_500,al_c,q_80,usm_0.66_1.00_0.01,enc_avif,quality_auto/Youth%20Basketball_edited.jpg';
---

<MainLayout
  title="About Geelong Stars | All-Abilities Sports Club"
  description="Learn about Geelong All-Abilities Sports Club. We offer inclusive programs for participants of all ages and abilities. Everyone belongs here!"
  url="/our-club"
>
  <!-- Hero Section -->
  <section class="relative min-h-[400px] flex items-center">
    <div class="absolute inset-0">
      <img
        src={HERO_IMAGE}
        alt="Geelong Stars Community"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/80 to-navy/50"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
          About Geelong Stars
        </h1>
        <p class="text-xl text-white/90">
          We're more than just a sports club - we're a community where everyone
          belongs, everyone plays, and everyone shines!
        </p>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-navy mb-6">
            Where Everyone Gets to Play!
          </h2>

          <div class="space-y-4 text-gray-600 text-lg leading-relaxed">
            <p>
              <strong class="text-navy">Geelong All-Abilities Sports Club</strong> offers
              a range of programs to meet the needs of all of our members, no matter your
              age or ability.
            </p>
            <p>
              At Geelong Stars, everyone is encouraged to get active, have fun, and build
              community through sports! We believe that sport has the power to bring people
              together, build confidence, and create lasting friendships.
            </p>
            <p>
              No matter your age, ability, or experience level — everyone is welcome at
              Geelong Stars. Whether you're here to try something new, build confidence,
              make friends, or just have fun, there's a place for you here. Come join our family!
            </p>
            <p class="font-semibold text-navy">Programs:</p>
            <ul class="list-disc list-inside space-y-1">
              <li>Minis – 5 to 12</li>
              <li>Youth – 12 to 18</li>
              <li>Learn to Ride</li>
              <li>Outdoor Adventures</li>
              <li>Achilles Running/Walking</li>
            </ul>
          </div>

          <div class="mt-8">
            <a
              href="/programs"
              class="inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 bg-navy text-white hover:bg-navy-600 focus:ring-navy-300 px-6 py-3 text-base"
            >
              Explore Our Programs
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src={TEAM_IMAGE}
              alt="Geelong Stars players"
              class="w-full h-auto"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy/30 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 lg:py-24 relative">
    <div class="absolute inset-0">
      <img
        src={TEAM_IMAGE}
        alt="Geelong Stars values"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/85 to-navy/75"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          What Makes Us Unique
        </h2>
        <p class="text-lg text-white/90 max-w-2xl mx-auto">
          Our core values guide everything we do - creating a welcoming space for all!
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- All Abilities Welcome -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="w-14 h-14 bg-blue-500 rounded-xl flex items-center justify-center mx-auto mb-4">
            <!-- Accessibility icon -->
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="4.5" r="1.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M6.5 8h11M9 8v8l-1.5 5M15 8v8l1.5 5M12 8v4"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">All Abilities Welcome</h3>
          <p class="text-gray-600 text-sm">Programs designed for participants of every ability level. Everyone belongs here!</p>
        </div>

        <!-- Community First -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="w-14 h-14 bg-green-500 rounded-xl flex items-center justify-center mx-auto mb-4">
            <!-- Users icon -->
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Community First</h3>
          <p class="text-gray-600 text-sm">Building friendships and connections that last a lifetime.</p>
        </div>

        <!-- Fun & Friendship -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="w-14 h-14 bg-pink-500 rounded-xl flex items-center justify-center mx-auto mb-4">
            <!-- Heart icon -->
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Fun & Friendship</h3>
          <p class="text-gray-600 text-sm">We believe sport should be enjoyable for everyone. Fun comes first!</p>
        </div>

        <!-- Everyone is a Star -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="w-14 h-14 bg-yellow-500 rounded-xl flex items-center justify-center mx-auto mb-4">
            <!-- Star icon -->
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Everyone is a Star</h3>
          <p class="text-gray-600 text-sm">Every participant is valued, celebrated, and encouraged to shine.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Join Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">
          Why Join Geelong Stars?
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Here's why our members love being part of our community!
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Supportive Environment -->
        <div class="flex items-start gap-4 bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-navy/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <!-- HeartHandshake icon -->
            <svg class="w-6 h-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/><path stroke-linecap="round" stroke-linejoin="round" d="m18 15-2-2"/><path stroke-linecap="round" stroke-linejoin="round" d="m15 18-2-2"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-navy mb-2">Supportive Environment</h3>
            <p class="text-gray-600">Trained coaches and volunteers who understand and celebrate all abilities.</p>
          </div>
        </div>

        <!-- Welcoming Community -->
        <div class="flex items-start gap-4 bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-navy/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <!-- Smile icon -->
            <svg class="w-6 h-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-navy mb-2">Welcoming Community</h3>
            <p class="text-gray-600">Make friends, have fun, and be part of something special.</p>
          </div>
        </div>

        <!-- Skill Development -->
        <div class="flex items-start gap-4 bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-navy/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <!-- Target icon -->
            <svg class="w-6 h-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-navy mb-2">Skill Development</h3>
            <p class="text-gray-600">Develop skills at your own pace with highly adaptive programs.</p>
          </div>
        </div>

        <!-- Celebrate Success -->
        <div class="flex items-start gap-4 bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-navy/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <!-- Award icon -->
            <svg class="w-6 h-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-navy mb-2">Celebrate Success</h3>
            <p class="text-gray-600">Every achievement is celebrated, no matter how big or small.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission Section -->
  <section class="py-16 lg:py-24 bg-gradient-to-r from-navy to-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
          <!-- Target icon -->
          <svg class="w-4 h-4 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          <span class="text-white/90 text-sm font-medium">Our Mission</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Creating Opportunities for Everyone
        </h2>
        <p class="text-xl text-white/90 leading-relaxed">
          Our mission is to promote physical activity, social inclusion, and personal
          development through a diverse range of sports and recreational activities.
          We believe that everyone deserves the opportunity to participate in sports,
          regardless of their physical or cognitive abilities.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-yellow-400 to-yellow-500 rounded-3xl p-8 md:p-12 text-center relative overflow-hidden">
        <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">
          Ready to Join the Stars?
        </h2>
        <p class="text-xl text-navy/80 mb-8 max-w-2xl mx-auto">
          We'd love to welcome you to our community! Get in touch to learn more,
          arrange a visit, or sign up for a program. Everyone is welcome!
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 bg-navy text-white hover:bg-navy-600 focus:ring-navy-300 px-6 py-3 text-base"
          >
            Get In Touch
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <a
            href="/programs"
            class="inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 border-2 border-navy text-navy hover:bg-navy hover:text-white focus:ring-navy-300 px-6 py-3 text-base"
          >
            View Programs
          </a>
          <a
            href="/membership"
            class="inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 border-2 border-navy text-navy hover:bg-navy hover:text-white focus:ring-navy-300 px-6 py-3 text-base"
          >
            Become a Member
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
