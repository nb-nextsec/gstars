---
export const prerender = false;

import MainLayout from '../layouts/MainLayout.astro';

const env = Astro.locals.runtime.env;
let sponsors: any[] = [];
try {
  const r = await env.DB.prepare('SELECT * FROM sponsors WHERE is_active = 1 ORDER BY display_order ASC, name ASC').all();
  sponsors = r.results || [];
} catch (e) {
  console.error('Failed to fetch sponsors:', e);
}

const HERO_IMAGE = 'https://static.wixstatic.com/media/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg/v1/fill/w_1200,h_600,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/c23ea9_1071a90c20b044f4bb98e30faed73a2c~mv2.jpg';
---

<MainLayout
  title="Our Sponsors | Geelong Stars Partners"
  description="Thank you to our amazing sponsors and partners whose generous support makes our programs possible. Partner with Geelong Stars today!"
  url="/sponsors"
>
  <!-- Hero -->
  <section class="relative min-h-[400px] flex items-center">
    <div class="absolute inset-0">
      <img src={HERO_IMAGE} alt="Geelong Stars Sponsors" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/80 to-navy/50"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Our Sponsors</h1>
        <p class="text-xl text-white/90">
          Thank you to our amazing sponsors and partners whose generous support
          makes our programs and community activities possible.
        </p>
      </div>
    </div>
  </section>

  <!-- Sponsors Grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sponsors.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sponsors.map((sponsor) => {
            const inner = (
              <>
                <div class="sponsor-logo-container h-56 bg-white flex items-center justify-center p-4">
                  {sponsor.logo_url ? (
                    <img src={sponsor.logo_url} alt={sponsor.name} class="h-44 w-auto max-w-full object-contain group-hover:scale-105 transition-transform duration-300" />
                  ) : (
                    <span class="text-2xl font-bold text-navy/70 text-center">{sponsor.name}</span>
                  )}
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold text-navy mb-2 group-hover:text-accent transition-colors">{sponsor.name}</h3>
                  {sponsor.description && <p class="text-gray-600 leading-relaxed">{sponsor.description}</p>}
                </div>
              </>
            );
            return sponsor.website_url ? (
              <a href={sponsor.website_url} target="_blank" rel="noopener noreferrer" class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
                {inner}
              </a>
            ) : (
              <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
                {inner}
              </div>
            );
          })}
        </div>
      ) : (
        <p class="text-center text-gray-500">No sponsors to display.</p>
      )}
    </div>
  </section>

  <!-- Become a Sponsor -->
  <section class="py-16 lg:py-24 bg-gradient-to-r from-navy to-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Become a Sponsor</h2>
          <p class="text-white/90 mb-6">
            Partner with Geelong Stars and support the development of athletes
            in our community. We offer various sponsorship packages to suit
            businesses of all sizes.
          </p>
          <p class="text-white/90 mb-8">
            As a sponsor, you'll receive brand exposure, community recognition,
            and the satisfaction of knowing you're making a real difference in
            the lives of many local families, by helping to make sport and
            recreation activities accessible for them.
          </p>
          <a href="/partner-with-us" class="inline-flex items-center justify-center gap-2 font-bold rounded-lg px-4 py-2 text-sm bg-yellow-400 text-navy hover:bg-yellow-300 transition-colors">
            Partner With Us
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
        <div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-8">
            <h3 class="text-xl font-semibold text-white mb-6">Sponsorship Benefits</h3>
            <ul class="space-y-4">
              {['Logo placement on club website and social media', 'Recognition at club events and functions', 'Signage opportunities at Stars HQ', 'Networking opportunities with other sponsors', 'Community goodwill and brand association'].map((benefit) => (
                <li class="flex items-start gap-3">
                  <div class="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  <span class="text-white/90">{benefit}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Thank You -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-navy mb-4">Thank You!</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        To all our sponsors, partners, and supporters - your contributions make
        it possible for us to provide quality sporting programs and build a
        stronger community. We couldn't do it without you!
      </p>
    </div>
  </section>
</MainLayout>
