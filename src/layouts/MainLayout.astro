---
import Navigation from '../components/layout/Navigation';
import '../styles/index.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const siteUrl = 'https://geelong-stars.pages.dev';
const {
  title,
  description,
  image = '/images/og-default.jpg',
  url = '',
  type = 'website',
  noindex = false,
} = Astro.props;

const fullUrl = url ? `${siteUrl}${url}` : siteUrl;
const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:site_name" content="Geelong Stars" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullImageUrl} />

    <!-- Canonical URL -->
    <link rel="canonical" href={fullUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SportsClub",
      "name": "Geelong Stars",
      "alternateName": "Geelong All Abilities Sports Club",
      "url": siteUrl,
      "logo": `${siteUrl}/images/logo.avif`,
      "description": "An all-abilities sports club in Geelong building community through fun, friendship, and sport. Programs include basketball, football, cricket, golf, cycling, boxing, athletics, and more.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "203 St Albans Road",
        "addressLocality": "Thomson",
        "addressRegion": "VIC",
        "postalCode": "3219",
        "addressCountry": "AU"
      },
      "telephone": "+61403017977",
      "email": "contact@geelongstars.com.au",
      "sameAs": [
        "https://www.facebook.com/p/Geelong-All-Abilities-Sports-Club-61563454708703/",
        "https://www.instagram.com/geelongallabilities/"
      ]
    })} />

    <slot name="head" />
  </head>
  <body>
    <div class="min-h-screen flex flex-col bg-white">
      <!-- Header -->
      <header class="bg-navy sticky top-0 z-50 shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-24">
            <a href="/" class="flex items-center gap-2 text-white hover:opacity-90 transition-opacity">
              <img src="/images/logo.avif" alt="Geelong Stars" class="h-24 w-auto" />
              <span class="text-4xl font-bold hidden sm:block">Geelong Stars</span>
            </a>
            <Navigation client:load />
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <main class="flex-1">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="bg-navy-700 text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
            <!-- Brand -->
            <div class="space-y-4">
              <a href="/" class="flex items-center gap-2">
                <img src="/images/logo.avif" alt="Geelong Stars" class="h-12 w-auto" />
                <span class="text-xl font-bold">Geelong Stars</span>
              </a>
              <p class="text-white/70 text-sm max-w-sm leading-relaxed">
                Where everyone plays, everyone belongs! An all-abilities sports club
                building community through fun, friendship, and sport.
              </p>
              <div class="flex gap-4">
                <a
                  href="https://www.facebook.com/p/Geelong-All-Abilities-Sports-Club-61563454708703/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors"
                  aria-label="Facebook"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a
                  href="https://www.instagram.com/geelongallabilities/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors"
                  aria-label="Instagram"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              </div>
            </div>

            <!-- Quick Links -->
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-3">Quick Links</h3>
              <ul class="grid grid-cols-2 gap-x-6 gap-y-2">
                <li><a href="/" class="text-white/70 hover:text-white transition-colors text-sm">Home</a></li>
                <li><a href="/our-club" class="text-white/70 hover:text-white transition-colors text-sm">Our Club</a></li>
                <li><a href="/programs" class="text-white/70 hover:text-white transition-colors text-sm">Our Programs</a></li>
                <li><a href="/social" class="text-white/70 hover:text-white transition-colors text-sm">News and Events</a></li>
                <li><a href="/photo-gallery" class="text-white/70 hover:text-white transition-colors text-sm">Photo Gallery</a></li>
                <li><a href="/sponsors" class="text-white/70 hover:text-white transition-colors text-sm">Sponsors</a></li>
                <li><a href="/membership" class="text-white/70 hover:text-white transition-colors text-sm">Membership</a></li>
                <li><a href="/thursday-meals" class="text-white/70 hover:text-white transition-colors text-sm">Thursday Meals</a></li>
                <li><a href="/shop-apparel" class="text-white/70 hover:text-white transition-colors text-sm">Shop Apparel</a></li>
                <li><a href="/partner-with-us" class="text-white/70 hover:text-white transition-colors text-sm">Partner With Us</a></li>
                <li><a href="/club-policies" class="text-white/70 hover:text-white transition-colors text-sm">Club Policies</a></li>
                <li><a href="/contact" class="text-white/70 hover:text-white transition-colors text-sm">Contact</a></li>
              </ul>
            </div>

            <!-- Get In Touch -->
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-3">Get In Touch</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3 text-sm">
                  <svg class="w-[18px] h-[18px] text-white/70 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                  <span class="text-white/70">203 St Albans Road<br />Thomson VIC 3219</span>
                </li>
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-[18px] h-[18px] text-white/70 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
                  <a href="tel:0403017977" class="text-white/70 hover:text-white transition-colors">0403 017 977</a>
                </li>
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-[18px] h-[18px] text-white/70 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
                  <a href="mailto:contact@geelongstars.com.au" class="text-white/70 hover:text-white transition-colors">contact@geelongstars.com.au</a>
                </li>
              </ul>
            </div>
          </div>

          <!-- Bottom Bar -->
          <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
            <p class="text-white/50 text-sm flex items-center gap-1">
              &copy; {currentYear} Geelong Stars. Made with <svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg> in Geelong
            </p>
            <div class="flex items-center gap-4">
              <a href="/terms-of-service" class="text-white/50 text-sm hover:text-white transition-colors">Terms of Service</a>
              <a href="/cookie-policy" class="text-white/50 text-sm hover:text-white transition-colors">Cookie Policy</a>
              <a href="/privacy-policy" class="text-white/50 text-sm hover:text-white transition-colors">Privacy Policy</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
